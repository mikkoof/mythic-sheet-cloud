generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  createdAt     DateTime  @default(now())

  accounts        Account[]
  sessions        Session[]
  campaignsAsGm   Campaign[]       @relation("CampaignGM")
  campaignMembers CampaignMember[]
  knights         Knight[]         @relation("KnightPlayer")
  invitesSent     CampaignInvite[] @relation("InvitesSent")
}

enum CampaignRole {
  gm
  player
}

model Campaign {
  id          String   @id @default(cuid())
  name        String
  description String?
  gmUserId    String
  createdAt   DateTime @default(now())

  gm      User             @relation("CampaignGM", fields: [gmUserId], references: [id], onDelete: Restrict)
  members CampaignMember[]
  knights Knight[]
  invites CampaignInvite[]

  @@index([gmUserId])
}

model CampaignInvite {
  id              String   @id @default(cuid())
  campaignId      String
  email           String
  invitedByUserId String
  createdAt       DateTime @default(now())

  campaign  Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  invitedBy User     @relation("InvitesSent", fields: [invitedByUserId], references: [id], onDelete: Cascade)

  @@unique([campaignId, email])
  @@index([email])
}

model CampaignMember {
  campaignId String
  userId     String
  role       CampaignRole
  joinedAt   DateTime     @default(now())

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([campaignId, userId])
  @@index([userId])
}

enum KnightAge {
  young
  mature
  old
}

enum KnightStatus {
  active
  retired
  dead
}

model Knight {
  id                  String  @id @default(cuid())
  campaignId          String
  playerUserId        String
  predecessorKnightId String?

  status KnightStatus @default(active)

  name         String
  epithet      String @default("")
  ultimateFate String @default("") @db.Text

  vigRemaining   Int @default(0)
  vigMax         Int @default(0)
  claRemaining   Int @default(0)
  claMax         Int @default(0)
  spiRemaining   Int @default(0)
  spiMax         Int @default(0)
  guardRemaining Int @default(0)
  guardMax       Int @default(0)

  vigTraits String[] @default(["", "", ""])
  claTraits String[] @default(["", "", ""])
  spiTraits String[] @default(["", "", ""])

  glory Int       @default(0)
  age   KnightAge @default(young)

  fatigued  Boolean @default(false)
  exposed   Boolean @default(false)
  exhausted Boolean @default(false)
  impaired  Boolean @default(false)

  ability String @default("") @db.Text
  passion String @default("") @db.Text

  property           String[] @default([])
  weapons            Json     @default("[]")
  protectiveArticles Json     @default("[]")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  campaign    Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  player      User     @relation("KnightPlayer", fields: [playerUserId], references: [id], onDelete: Cascade)
  predecessor Knight?  @relation("KnightSuccession", fields: [predecessorKnightId], references: [id], onDelete: SetNull)
  successors  Knight[] @relation("KnightSuccession")
  steeds      Steed[]
  squires     Squire[]

  @@index([campaignId])
  @@index([playerUserId])
  @@index([predecessorKnightId])
  @@index([campaignId, status])
}

model Steed {
  id       String @id @default(cuid())
  knightId String

  name String    @default("")
  age  KnightAge @default(young)

  vigRemaining   Int @default(0)
  vigMax         Int @default(0)
  claRemaining   Int @default(0)
  claMax         Int @default(0)
  spiRemaining   Int @default(0)
  spiMax         Int @default(0)
  guardRemaining Int @default(0)
  guardMax       Int @default(0)

  property String[] @default([])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  knight Knight @relation(fields: [knightId], references: [id], onDelete: Cascade)

  @@index([knightId])
}

model Squire {
  id       String @id @default(cuid())
  knightId String

  name String    @default("")
  age  KnightAge @default(young)

  vigRemaining   Int @default(0)
  vigMax         Int @default(0)
  claRemaining   Int @default(0)
  claMax         Int @default(0)
  spiRemaining   Int @default(0)
  spiMax         Int @default(0)
  guardRemaining Int @default(0)
  guardMax       Int @default(0)

  property String[] @default([])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  knight Knight @relation(fields: [knightId], references: [id], onDelete: Cascade)

  @@index([knightId])
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@id([identifier, token])
}
